`include "apb_interface.sv"
`include "apb_pkg.sv"

import apb_pkg::*;

module testbench;

bit pclk;
bit rst_n;

// Interface
apb_interface vif();
  initial begin
   $dumpfile("apb_wave.vcd");
   $dumpvars(0, testbench);
end

// Test handle
apb_test test_h;

// DUT instantiation
apb_slave DUT(.dif(vif));

// Clock generation
initial begin
   vif.pclk = 0;
   forever #5 vif.pclk = ~vif.pclk;
end

// Reset generation
initial begin
   vif.rst_n = 0;
   #40;
   vif.rst_n = 1;
end

// Run test
initial begin
   test_h = new(vif, vif, vif);
   test_h.build_and_run();
   #2000 $finish;
end

endmodule
